{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FoxForge GG",
  "version": "0.1.3",
  "identifier": "gg.aerokita.unitebuildoptimizer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FoxForge GG",
        "width": 1280,
        "height": 860,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AeroKita/FoxForge-GG/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFNTU3NUY5OTFBNzg4MDEKUldRQmlLZVIrWFZWbnJEblE1b0tTRWJRQTBjeVFCQStuNE5Ba0pMOGlsK0tkNk96MHk2OCs0dGEK"
    }
  }
}
