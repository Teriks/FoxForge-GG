{
  "name": "unite-build-optimizer",
  "private": true,
  "version": "1.4.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/engine/validate.ts",
    "generate:presets": "node --import tsx tools/meta-defaults/generate-presets.ts",
    "generate:presets:dry": "node --import tsx tools/meta-defaults/generate-presets.ts --dry",
    "data:post-normalize": "python3 tools/community/normalize.py && npm run generate:presets",
    "data:publish": "python3 tools/community/publish_bundle.py",
    "data:publish:check": "python3 tools/community/publish_bundle.py --check",
    "data:doctor": "python3 tools/community/doctor.py",
    "data:refresh": "python3 tools/community/refresh.py",
    "data:curate": "python3 tools/community/curate.py",
    "data:gaps": "python3 tools/community/gaps.py",
    "validate:art": "python3 tools/community/validate_art.py",
    "fetch:art": "python3 tools/community/fetch_art.py",
    "fetch:gifs": "python3 tools/community/fetch_gifs.py",
    "build:pages": "VITE_BASE=/FoxForge-GG/ npm run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt \"src/**/*.{ts,tsx}\" vite.config.ts",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx}\" vite.config.ts",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run validate && npx tsx src/data/verifyPatch.ts && npm run validate:art",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "oxfmt",
    "vite.config.ts": "oxfmt"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
